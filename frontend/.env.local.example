# ── Supabase ──────────────────────────────────────────────────────────────────
# 1. Create a project at https://supabase.com
# 2. Project Settings → API → Project URL
# 3. Project Settings → API → Project API Keys → anon (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Backend API ───────────────────────────────────────────────────────────────
# From browser on same machine: http://localhost:8000
# If backend runs on Windows and frontend on WSL: http://172.28.48.1:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
