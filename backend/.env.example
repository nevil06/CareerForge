# ── Database ──────────────────────────────────────────────────────────────────
# From Windows/CMD:   mysql+pymysql://root:PASSWORD@localhost:3306/carrier_forge
# From WSL:           mysql+pymysql://root:PASSWORD@<windows-host-ip>:3306/carrier_forge
# Special chars in password must be URL-encoded: @ → %40, # → %23
DATABASE_URL=mysql+pymysql://root:YOUR_PASSWORD@localhost:3306/carrier_forge

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string

# ── ZhipuAI GLM ───────────────────────────────────────────────────────────────
# Get your key at https://console.zhipuai.cn
# Models used: glm-5.1 (chat), embedding-3 (semantic matching)
ZHIPU_API_KEY=your-zhipuai-api-key

# ── Brevo Transactional Email ─────────────────────────────────────────────────
# 1. Login to https://app.brevo.com
# 2. Top-right → SMTP & API → API Keys → Generate key
# 3. Senders & IP → Senders → verify your sender email
BREVO_API_KEY=xkeysib-your-api-key-here
BREVO_SENDER_EMAIL=your-verified-sender@email.com
BREVO_SENDER_NAME=CareerForge

# ── Supabase Auth ─────────────────────────────────────────────────────────────
# 1. Create a project at https://supabase.com
# 2. Project Settings → API → Project URL
# 3. Project Settings → API → JWT Secret  (under "JWT Settings")
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── JSearch API via RapidAPI (real job listings) ──────────────────────────────
# Subscribe at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=your-rapidapi-key-here

# ── Adzuna Job API (optional legacy fallback) ─────────────────────────────────
# Register at https://developer.adzuna.com
JOB_API_APP_ID=
JOB_API_KEY=
